# Polymarket CLOB API 认证（在 Polymarket 网站 Profile → API Keys 生成）
# 复制本文件为 .env，填入你的真实值，.env 已在 .gitignore 中，不会被提交

POLY_API_KEY=your-api-key-here
POLY_API_SECRET=your-api-secret-here
POLY_API_PASSPHRASE=your-passphrase-here

# AI Oracle — DeepSeek
DEEPSEEK_API_KEY=sk-your-deepseek-key-here

# AI Oracle — Brave Search（可选，有则联网搜索，没有则只用 DeepSeek）
BRAVE_API_KEY=BSA-your-brave-key-here
